# Copia este archivo como ".env" y completa los valores reales.
# Nunca subas el archivo ".env" con credenciales reales a un repositorio público.

# --- CORS: dominio(s) desde donde se llamará a la API (tu sitio WordPress) ---
ALLOWED_ORIGINS=https://www.tudominio.com

# --- Google PageSpeed Insights (opcional pero recomendado) ---
# Obtener clave gratuita: https://developers.google.com/speed/docs/insights/v5/get-started
ENABLE_PAGESPEED=false
PAGESPEED_API_KEY=

# --- Envío de correo (SMTP) ---
# Puede ser el SMTP de tu hosting, o un servicio transaccional (Brevo, Mailgun, SendGrid)
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=usuario@tudominio.com
SMTP_PASS=contraseña-o-api-key
SMTP_FROM=diagnosticos@tudominio.com
SMTP_USE_TLS=true

# --- Notificación al equipo comercial ---
NOTIFY_EMAIL=ventas@tudominio.com

# --- Branding del informe PDF ---
COMPANY_NAME=Tu Agencia SEO
BRAND_PRIMARY_COLOR=#2E5395
BRAND_ACCENT_COLOR=#F2A20C
BRAND_LOGO_PATH=
BRAND_CTA_TEXT=¿Quieres mejorar estos resultados? Agenda una asesoría gratuita con nuestro equipo de SEO.
BRAND_CTA_URL=https://www.tudominio.com/contacto
BRAND_CONTACT_EMAIL=contacto@tudominio.com

# --- Análisis ejecutivo generado con IA (opcional) ---
# Activa esto para que el informe incluya veredicto + resumen ejecutivo +
# prioridades + plan de acción personalizados, redactados por IA.
ENABLE_AI_SUMMARY=true

# Proveedor de IA: gemini | groq | anthropic
# (si lo dejas vacío, autodetecta según la key que tengas configurada)
AI_PROVIDER=gemini

# --- Google Gemini (GRATIS, recomendado para empezar) ---
# Key gratuita, sin tarjeta: https://aistudio.google.com -> "Get API key"
GEMINI_API_KEY=

# --- Groq (alternativa gratis) ---
# Key gratuita: https://console.groq.com
GROQ_API_KEY=

# --- Anthropic / Claude (de pago, mayor calidad) ---
ANTHROPIC_API_KEY=

# Modelo a usar (opcional). Si lo dejas vacío, cada proveedor usa su modelo
# por defecto: gemini-2.0-flash | llama-3.3-70b-versatile | claude-haiku-4-5
AI_MODEL=

# --- Pasarela de pagos Stripe ---
# Claves en: https://dashboard.stripe.com/apikeys
# Usa sk_test_... para pruebas y sk_live_... para produccion
STRIPE_SECRET_KEY=sk_test_...
# ID del precio del producto (price_...) en Stripe Dashboard
STRIPE_PRICE_ID=price_...
# Secreto del webhook (whsec_...) en Stripe Dashboard -> Developers -> Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# URL publica del widget Next.js en Vercel (sin / al final)
APP_BASE_URL=https://tu-widget.vercel.app
